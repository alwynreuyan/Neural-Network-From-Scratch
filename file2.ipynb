   "metadata": {},
   "outputs": [],
   "source": [
    "image = cv2.imread('jen.jpg', 0)\n",
    "cv2.imshow('profile', image)\n",
    "k = cv2.waitKey(0)\n",
    "\n",
    "if k == 27:\n",
    "    cv2.destroyAllWindows()\n",
    "elif k == ord('s'):\n",
    "    cv2.imwrite('jen_copy.jpg', image)\n",
    "    cv2.destroyAllWindows()"
   ]
